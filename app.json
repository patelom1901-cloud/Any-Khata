{
  "expo": {
    "name": "Any Khata",
    "slug": "any-khata",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "anykhata",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#FAF4EE"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anykhata.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F4C75"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anykhata.app",
      "permissions": []
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-sqlite",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6023840028537006~8324267639"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d655befc-66be-4e7e-87b6-c50a687a8abc"
      }
    }
  }
}